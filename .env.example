NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Neon PostgreSQL
DATABASE_URL=

# Coach admin access (Clerk user ID of the coach)
ADMIN_USER_ID=user_your_clerk_user_id_here

# TMDB API (movie/series search) — https://www.themoviedb.org/settings/api
# v3 API keys are 32 characters; copy the key exactly with no extra characters.
TMDB_API_KEY=your_tmdb_api_key_here

# Google Gemini API (schedule screenshot import) — https://aistudio.google.com/apikey
# Free tier works for weekly screenshot imports. Default model: gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# YouTube to MP3 converter — requires yt-dlp + ffmpeg on the server
# https://github.com/yt-dlp/yt-dlp#installation
# YT_DLP_PATH=/usr/local/bin/yt-dlp
