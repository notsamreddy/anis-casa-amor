NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Neon PostgreSQL
DATABASE_URL=

# Coach admin access (Clerk user ID of the coach)
ADMIN_USER_ID=user_your_clerk_user_id_here

# TMDB API (movie/series search) — https://www.themoviedb.org/settings/api
# v3 API keys are 32 characters; copy the key exactly with no extra characters.
TMDB_API_KEY=your_tmdb_api_key_here

# Google Gemini API (schedule screenshot import) — https://aistudio.google.com/apikey
# Free tier works for weekly screenshot imports. Default model: gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# Spotify Web API — https://developer.spotify.com/dashboard
# Spotify requires 127.0.0.1 for the OAuth callback (not localhost).
# Browse the app itself at http://localhost:3000 so Clerk sign-in works.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback

# Discord bot — https://discord.com/developers/applications
# Generate a long random secret shared by the Next.js API and the bot process.
DISCORD_BOT_SECRET=generate_a_long_random_secret
# Optional fallback map (DB links via /link are preferred)
DISCORD_USER_MAP={"your_discord_user_id":"user_your_clerk_user_id_here"}
# Used only by the discord-bot process:
# DISCORD_BOT_TOKEN=
# DISCORD_CLIENT_ID=
# DISCORD_GUILD_ID=  (optional: register slash commands to one server instantly)
# DISCORD_REMINDER_CHANNEL_ID=  (channel for 1-hour shift reminders)
# CASA_API_URL=http://localhost:3000
