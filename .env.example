NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Neon PostgreSQL
DATABASE_URL=

# Coach admin access (Clerk user ID of the coach)
ADMIN_USER_ID=user_your_clerk_user_id_here

# TMDB API (movie/series search) — https://www.themoviedb.org/settings/api
# v3 API keys are 32 characters; copy the key exactly with no extra characters.
TMDB_API_KEY=your_tmdb_api_key_here
